# HTML pages — revalidate on every request so deploys are visible immediately
/
  Cache-Control: no-cache, must-revalidate

/*.html
  Cache-Control: no-cache, must-revalidate

# Hashed static assets — safe to cache for a year
/assets/*
  Cache-Control: max-age=31536000, immutable

# Generated search assets — refreshed during deploy and safe to cache briefly
/output/*
  Cache-Control: max-age=86400

/philosophy-output/*
  Cache-Control: max-age=86400

/blog/rss.xml
  Content-Type: application/rss+xml; charset=utf-8

/philosophy/rss.xml
  Content-Type: application/rss+xml; charset=utf-8

# Everything else (images, fonts, etc.) — moderate cache
/*
  Cache-Control: max-age=3600
